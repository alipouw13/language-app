# ============================================================================
# Language Learning App — Backend Configuration
# Copy to .env and fill in real values. NEVER commit .env.
#
# There are TWO independent auth layers — don't confuse them:
#
#   1. Service -> Azure (always on): the backend calls Azure OpenAI, Foundry
#      and OneLake using Microsoft Entra via DefaultAzureCredential. Locally
#      this is just your `az login`; when hosted it's a managed identity.
#      No API keys, no app registration. This is all you need to RUN the app.
#
#   2. User -> this API (optional, the ENTRA_* block below): only required if
#      you HOST the app for multiple sign-in users and want per-user data and
#      a protected API. Leave it disabled for single-user / local use — your
#      `az login` already covers layer 1.
# ============================================================================

# --- Storage: Fabric OneLake Lakehouse (Delta tables) ----------------------
# "local"   → Delta tables on disk (dev / tests)
# "onelake" → Delta tables in a Fabric Lakehouse over abfss (Entra auth)
STORAGE_BACKEND=local
LOCAL_LAKEHOUSE_PATH=./.lakehouse

# For STORAGE_BACKEND=onelake, set the Fabric workspace + lakehouse
# (names or GUIDs both work). The identity needs Contributor on the workspace.
ONELAKE_WORKSPACE=<workspace-name-or-guid>
ONELAKE_LAKEHOUSE=<lakehouse-name-or-guid>
# ONELAKE_HOST=onelake.dfs.fabric.microsoft.com

# --- Azure OpenAI (chat / evaluation — Entra authentication) ---------------
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT=gpt-4.1-mini

# --- Azure AI Foundry (speech + translation models — Entra auth) -----------
# Base resource endpoint. A trailing "/openai" is tolerated and stripped.
AZURE_FOUNDRY_ENDPOINT=https://<foundry-resource>.cognitiveservices.azure.com/
AZURE_FOUNDRY_API_VERSION=2025-03-01-preview

# Speech model deployments (see README for what to deploy).
AZURE_SPEECH_TO_TEXT_MODEL_NAME=gpt-4o-transcribe
AZURE_TEXT_TO_SPEECH_MODEL_NAME=gpt-4o-mini-tts

# Optional dedicated translation deployment. Leave empty to reuse the chat model.
AZURE_TRANSLATION_MODEL_NAME=

# Optional embedding deployment (e.g. text-embedding-3-small) used to vectorize
# news for semantic retrieval. Leave empty to fall back to recency + level only.
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=

# --- Real-Time Intelligence: news stream (Fabric Eventhouse / KQL) ----------
# "local"      → enriched news on disk (dev default; no Fabric needed)
# "eventhouse" → enriched news ingested into a Fabric Eventhouse (KQL DB)
RTI_BACKEND=local
LOCAL_RTI_PATH=./.rti

# For RTI_BACKEND=eventhouse, set the Eventhouse (KQL DB) connection. The URIs
# come from the Eventhouse "Cluster URI". The identity needs ingest + query
# rights on the database (Entra auth via DefaultAzureCredential).
EVENTHOUSE_QUERY_URI=https://<cluster>.kusto.fabric.microsoft.com
EVENTHOUSE_INGEST_URI=https://<cluster>.kusto.fabric.microsoft.com
EVENTHOUSE_DATABASE=<kql-database-name>
# EVENTHOUSE_NEWS_TABLE=news_enriched

# Languages to ingest current-events news for (subset of en/fr/es).
NEWS_LANGUAGES=["es","fr"]
GDELT_TIMESPAN=1d
GDELT_MAX_RECORDS=40
# Optional per-language GDELT query overrides (empty → built-in defaults).
GDELT_QUERY_ES=
GDELT_QUERY_FR=
GDELT_QUERY_EN=

NEWS_DEFAULT_LEVEL=B1
NEWS_MAX_AGE_HOURS=48

# Background poller: ingest news on a timer when the API is running.
NEWS_POLL_ENABLED=false
NEWS_POLL_INTERVAL_MINUTES=60

# --- API authentication: Microsoft Entra ID (layer 2 — OPTIONAL) -----------
# Leave ENTRA_AUTH_ENABLED=false for single-user / local use: your `az login`
# already authenticates the backend to Azure (layer 1). You only need to fill
# in the values below if you HOST this for multiple sign-in users (it makes
# users sign in to the web app and isolates each user's data).
ENTRA_AUTH_ENABLED=false
ENTRA_TENANT_ID=<tenant-id>
# Application ID URI / client id this API validates as the token audience.
ENTRA_API_AUDIENCE=api://<api-client-id>
# ENTRA_ADDITIONAL_AUDIENCES=["<api-client-id>"]

# --- App -------------------------------------------------------------------
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
LOG_LEVEL=INFO
