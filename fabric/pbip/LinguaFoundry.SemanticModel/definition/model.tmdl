model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	discourageImplicitMeasures
	sourceQueryCulture: en-US
	directLakeBehavior: directLakeOnly
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_ProTooling = ["RemoteModeling","DevMode"]

annotation PBI_QueryOrder = ["DirectLake"]

annotation __PBI_TimeIntelligenceEnabled = 1

ref table dim_user
ref table dim_date
ref table dim_language
ref table dim_cefr
ref table dim_scenario
ref table dim_news
ref table fact_submission
ref table fact_response
ref table fact_exercise_score
ref table fact_conversation
ref table fact_news_engagement

