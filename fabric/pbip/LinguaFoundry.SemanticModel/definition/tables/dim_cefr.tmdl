table dim_cefr

	column cefr_level
		dataType: string
		summarizeBy: none
		sourceColumn: cefr_level
		sortByColumn: cefr_order

	column cefr_order
		dataType: int64
		isHidden
		summarizeBy: none
		sourceColumn: cefr_order

	partition dim_cefr = entity
		mode: directLake
		source
			entityName: dim_cefr
			schemaName: dbo
			expressionSource: DirectLake
