# Frontend configuration (Vite). Copy to .env and adjust.
#
# OPTIONAL: user sign-in. Leave VITE_AUTH_ENABLED=false for single-user / local
# use — the backend already authenticates to Azure via your `az login`, so no
# sign-in is required. Only enable this (and register an Entra SPA app) if you
# host the app for multiple users.
VITE_AUTH_ENABLED=false
VITE_ENTRA_CLIENT_ID=<spa-app-client-id>
VITE_ENTRA_TENANT_ID=<tenant-id>
# Scope exposed by the backend API app registration, e.g.
# api://<api-client-id>/access_as_user
VITE_ENTRA_API_SCOPE=api://<api-client-id>/access_as_user
