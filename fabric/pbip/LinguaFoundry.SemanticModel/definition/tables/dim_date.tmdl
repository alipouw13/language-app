table dim_date

	column date_key
		dataType: int64
		isHidden
		summarizeBy: none
		sourceColumn: date_key

	column Date
		dataType: string
		summarizeBy: none
		sourceColumn: date

	column Year
		dataType: int64
		summarizeBy: none
		sourceColumn: year

	column Quarter
		dataType: int64
		summarizeBy: none
		sourceColumn: quarter

	column Month
		dataType: int64
		summarizeBy: none
		sourceColumn: month

	column 'Month Name'
		dataType: string
		summarizeBy: none
		sourceColumn: month_name
		sortByColumn: Month

	column 'Month Year'
		dataType: string
		summarizeBy: none
		sourceColumn: month_year

	column Day
		dataType: int64
		summarizeBy: none
		sourceColumn: day

	column 'Day Of Week'
		dataType: int64
		summarizeBy: none
		sourceColumn: day_of_week

	column 'Day Name'
		dataType: string
		summarizeBy: none
		sourceColumn: day_name
		sortByColumn: 'Day Of Week'

	column 'Week Of Year'
		dataType: int64
		summarizeBy: none
		sourceColumn: week_of_year

	column 'Is Weekend'
		dataType: boolean
		summarizeBy: none
		sourceColumn: is_weekend

	partition dim_date = entity
		mode: directLake
		source
			entityName: dim_date
			schemaName: dbo
			expressionSource: DirectLake
