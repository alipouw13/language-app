table dim_user

	/// Distinct learners in context.
	measure Learners = DISTINCTCOUNT(dim_user[user_id])
		formatString: #,##0

	column user_id
		dataType: string
		isHidden
		summarizeBy: none
		sourceColumn: user_id

	column user_name
		dataType: string
		summarizeBy: none
		sourceColumn: user_name

	column native_language
		dataType: string
		summarizeBy: none
		sourceColumn: native_language

	column created_date_key
		dataType: int64
		isHidden
		summarizeBy: none
		sourceColumn: created_date_key

	column is_sample
		dataType: boolean
		summarizeBy: none
		sourceColumn: is_sample

	partition dim_user = entity
		mode: directLake
		source
			entityName: dim_user
			schemaName: dbo
			expressionSource: DirectLake
