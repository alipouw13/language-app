table dim_date

	column date_key
		dataType: int64
		isHidden
		summarizeBy: none
		sourceColumn: date_key

	column date
		dataType: string
		summarizeBy: none
		sourceColumn: date

	column year
		dataType: int64
		summarizeBy: none
		sourceColumn: year

	column quarter
		dataType: int64
		summarizeBy: none
		sourceColumn: quarter

	column month
		dataType: int64
		summarizeBy: none
		sourceColumn: month

	column month_name
		dataType: string
		summarizeBy: none
		sourceColumn: month_name
		sortByColumn: month

	column month_year
		dataType: string
		summarizeBy: none
		sourceColumn: month_year

	column day
		dataType: int64
		summarizeBy: none
		sourceColumn: day

	column day_of_week
		dataType: int64
		summarizeBy: none
		sourceColumn: day_of_week

	column day_name
		dataType: string
		summarizeBy: none
		sourceColumn: day_name
		sortByColumn: day_of_week

	column week_of_year
		dataType: int64
		summarizeBy: none
		sourceColumn: week_of_year

	column is_weekend
		dataType: boolean
		summarizeBy: none
		sourceColumn: is_weekend

	partition dim_date = entity
		mode: directLake
		source
			entityName: dim_date
			schemaName: dbo
			expressionSource: DirectLake
